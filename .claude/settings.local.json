{
  "permissions": {
    "allow": [
      "Bash(npm run convex:*)",
      "Bash(npm run:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git remote add:*)",
      "Bash(git push:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(git checkout:*)",
      "Bash(npm install:*)",
      "Bash(npx tsc:*)",
      "Bash(npx convex dev:*)",
      "Bash(npx convex run:*)",
      "Bash(npx convex deploy:*)",
      "Bash(kill:*)",
      "Bash(npx convex logs:*)",
      "Bash(curl:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "Bash(for file in src/components/domain/charts/PositionDistributionChart.tsx src/components/domain/charts/LinkAttributesChart.tsx src/components/domain/charts/PlatformTypesChart.tsx)",
      "Bash(do sed -i '' 's/ChartLegendContent \\\\/>/ChartLegendContent payload={[]} \\\\/>/g' \"$file\")",
      "Bash(done)",
      "Bash(for file in src/components/domain/tables/CompetitorKeywordGapTable.tsx src/components/domain/tables/SERPFeaturesBadges.tsx)",
      "Bash(head:*)",
      "mcp__context7__resolve-library-id",
      "Bash(npx untitledui@latest:*)",
      "Bash(node:*)",
      "Bash(npx jest --listTests)",
      "mcp__Claude_Preview__preview_start",
      "Bash(lsof:*)",
      "Bash(ps:*)",
      "Bash(claude --version)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "graphiti-memory",
    "playwright"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/alex/projects/monitoring2/monitoring/.claude/hooks/commit-guard.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/alex/projects/monitoring2/monitoring/.claude/hooks/blast-radius-check.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
