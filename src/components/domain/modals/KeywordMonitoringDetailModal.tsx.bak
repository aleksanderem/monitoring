"use client";

import { XClose } from "@untitledui/icons";
import { Button } from "@/components/base/buttons/button";
import { KeywordPositionChart } from "../charts/KeywordPositionChart";
import { MonthlySearchTrendChart } from "../charts/MonthlySearchTrendChart";
import { useQuery } from "convex/react";
import { api } from "../../../../convex/_generated/api";

interface KeywordMonitoringDetailModalProps {
  keyword: any;
  isOpen: boolean;
  onClose: () => void;
}

function formatNumber(num: number | null | undefined): string {
  if (!num) return "—";
  if (num >= 1000000) return `${(num / 1000000).toFixed(1)}M`;
  if (num >= 1000) return `${(num / 1000).toFixed(1)}K`;
  return num.toString();
}

export function KeywordMonitoringDetailModal({ keyword, isOpen, onClose }: KeywordMonitoringDetailModalProps) {
  // Fetch SERP results for this keyword (show top 20 instead of 10)
  const serpResults = useQuery(
    api.keywords.getSerpResultsForKeyword,
    keyword?.keywordId ? { keywordId: keyword.keywordId, limit: 20 } : "skip"
  );

  if (!isOpen || !keyword) return null;

  return (
    <div className="fixed inset-0 z-50 flex items-center justify-center">
      {/* Backdrop */}
      <div
        className="absolute inset-0 bg-black/50 backdrop-blur-sm"
        onClick={onClose}
      />

      {/* Modal */}
      <div className="relative z-10 w-full max-w-6xl max-h-[90vh] overflow-y-auto mx-4">
        <div className="rounded-xl border border-secondary bg-primary shadow-xl">
          {/* Header */}
          <div className="flex items-center justify-between border-b border-secondary p-6">
            <div>
              <h2 className="text-xl font-semibold text-primary">{keyword.phrase}</h2>
              <div className="flex items-center gap-3 mt-2">
                {keyword.currentPosition && (
                  <span className="inline-flex items-center rounded-full bg-utility-success-50 px-3 py-1 text-sm font-medium text-utility-success-700">
                    Position #{keyword.currentPosition}
                  </span>
                )}
                {keyword.previousPosition && (
                  <span className="inline-flex items-center rounded-full bg-utility-gray-50 px-3 py-1 text-sm font-medium text-utility-gray-600">
                    Previous #{keyword.previousPosition}
                  </span>
                )}
                {keyword.change !== null && keyword.change !== 0 && (
                  <span
                    className={`inline-flex items-center gap-1 rounded-full px-3 py-1 text-sm font-medium ${
                      keyword.change > 0
                        ? "bg-utility-success-50 text-utility-success-700"
                        : "bg-utility-error-50 text-utility-error-700"
                    }`}
                  >
                    {keyword.change > 0 ? "↑" : "↓"} {Math.abs(keyword.change)}
                  </span>
                )}
                {keyword.searchVolume && (
                  <span className="text-sm text-tertiary">
                    {formatNumber(keyword.searchVolume)} monthly searches
                  </span>
                )}
              </div>
            </div>
            <Button
              size="sm"
              color="secondary"
              iconLeading={XClose}
              onClick={onClose}
            >
              Close
            </Button>
          </div>

          {/* Content */}
          <div className="p-6 space-y-6">
            {/* Position History Chart */}
            {keyword.positionHistory && keyword.positionHistory.length > 0 && (
              <div>
                <h3 className="text-base font-semibold text-primary mb-4">Position History</h3>
                <KeywordPositionChart positionHistory={keyword.positionHistory} />
              </div>
            )}

            {/* Monthly Search Trend Chart */}
            {keyword.monthlySearches && keyword.monthlySearches.length > 0 && (
              <div>
                <h3 className="text-base font-semibold text-primary mb-4">Search Volume Trend</h3>
                <MonthlySearchTrendChart monthlySearches={keyword.monthlySearches} />
              </div>
            )}

            {/* Keyword Metrics Grid */}
            <div>
              <h3 className="text-base font-semibold text-primary mb-4">Keyword Metrics</h3>
              <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                {keyword.searchVolume && (
                  <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                    <p className="text-xs font-medium text-tertiary mb-1">Search Volume</p>
                    <p className="text-lg font-semibold text-primary">{formatNumber(keyword.searchVolume)}</p>
                  </div>
                )}
                {keyword.difficulty !== null && keyword.difficulty !== undefined && (
                  <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                    <p className="text-xs font-medium text-tertiary mb-1">Difficulty</p>
                    <p className="text-lg font-semibold text-primary">{keyword.difficulty}</p>
                  </div>
                )}
                {keyword.cpc !== null && keyword.cpc !== undefined && (
                  <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                    <p className="text-xs font-medium text-tertiary mb-1">CPC</p>
                    <p className="text-lg font-semibold text-primary">${keyword.cpc.toFixed(2)}</p>
                  </div>
                )}
                {keyword.etv !== null && keyword.etv !== undefined && (
                  <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                    <p className="text-xs font-medium text-tertiary mb-1">ETV</p>
                    <p className="text-lg font-semibold text-primary">{keyword.etv.toFixed(2)}</p>
                  </div>
                )}
                {keyword.competition !== null && keyword.competition !== undefined && (
                  <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                    <p className="text-xs font-medium text-tertiary mb-1">Competition</p>
                    <p className="text-lg font-semibold text-primary">{(keyword.competition * 100).toFixed(0)}%</p>
                  </div>
                )}
                {keyword.intent && (
                  <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                    <p className="text-xs font-medium text-tertiary mb-1">Intent</p>
                    <p className="text-lg font-semibold text-primary capitalize">{keyword.intent}</p>
                  </div>
                )}
                {keyword.potential && (
                  <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                    <p className="text-xs font-medium text-tertiary mb-1">Potential Traffic</p>
                    <p className="text-lg font-semibold text-primary">{formatNumber(keyword.potential)}</p>
                  </div>
                )}
                {keyword.status && (
                  <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                    <p className="text-xs font-medium text-tertiary mb-1">Status</p>
                    <p className="text-lg font-semibold text-primary capitalize">{keyword.status}</p>
                  </div>
                )}
              </div>
            </div>

            {/* URL if available */}
            {keyword.url && (
              <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                <p className="text-xs font-medium text-tertiary mb-1">Ranking URL</p>
                <a
                  href={keyword.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  className="text-sm text-utility-blue-600 hover:text-utility-blue-700 hover:underline break-all"
                >
                  {keyword.url}
                </a>
              </div>
            )}

            {/* SERP Features */}
            {keyword.serpFeatures && keyword.serpFeatures.length > 0 && (
              <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                <p className="text-xs font-medium text-tertiary mb-2">SERP Features</p>
                <div className="flex flex-wrap gap-2">
                  {keyword.serpFeatures.map((feature: string, idx: number) => (
                    <span
                      key={idx}
                      className="inline-flex items-center rounded-full bg-utility-blue-50 px-2.5 py-0.5 text-xs font-medium text-utility-blue-700"
                    >
                      {feature}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {/* SERP Competitors */}
            {serpResults && serpResults.results.length > 0 && (
              <div>
                <div className="flex items-center justify-between mb-4">
                  <h3 className="text-base font-semibold text-primary">
                    🔍 SERP Competitors
                  </h3>
                  <span className="inline-flex items-center rounded-full bg-utility-blue-100 px-3 py-1 text-xs font-medium text-utility-blue-700">
                    Top {serpResults.results.length} results
                  </span>
                </div>
                <div className="space-y-3">
                  {serpResults.results.map((result, idx) => (
                    <div
                      key={idx}
                      className={`rounded-xl border ${
                        result.isYourDomain
                          ? "border-utility-success-300 bg-gradient-to-r from-utility-success-50 to-utility-success-50/30 shadow-sm"
                          : "border-secondary bg-primary hover:bg-secondary/30 hover:shadow-md transition-all duration-200"
                      } overflow-hidden`}
                    >
                      <div className="p-5">
                        <div className="flex items-start gap-4">
                          {/* Position Badge with color coding */}
                          <div className={`flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm shadow-sm ${
                            result.position === 1
                              ? "bg-gradient-to-br from-utility-warning-400 to-utility-warning-600 text-white ring-2 ring-utility-warning-200"
                              : result.position <= 3
                              ? "bg-gradient-to-br from-utility-success-400 to-utility-success-600 text-white"
                              : result.position <= 10
                              ? "bg-gradient-to-br from-utility-blue-400 to-utility-blue-600 text-white"
                              : "bg-gradient-to-br from-utility-gray-300 to-utility-gray-500 text-white"
                          }`}>
                            {result.position}
                          </div>
                          <div className="flex-1 min-w-0">
                            {/* Domain and badges */}
                            <div className="flex items-center gap-2 mb-2 flex-wrap">
                              <span
                                className={`text-base font-semibold ${
                                  result.isYourDomain
                                    ? "text-utility-success-700"
                                    : "text-primary"
                                }`}
                              >
                                {result.domain}
                              </span>
                              {result.isYourDomain && (
                                <span className="inline-flex items-center gap-1 rounded-full bg-gradient-to-r from-utility-success-100 to-utility-success-50 px-2.5 py-1 text-xs font-semibold text-utility-success-700 ring-1 ring-utility-success-300">
                                  ✓ Your Domain
                                </span>
                              )}
                              {result.isFeaturedSnippet && (
                                <span className="inline-flex items-center gap-1 rounded-full bg-gradient-to-r from-utility-purple-100 to-utility-purple-50 px-2.5 py-1 text-xs font-semibold text-utility-purple-700 ring-1 ring-utility-purple-300">
                                  ⭐ Featured
                                </span>
                              )}
                              {result.ampVersion && (
                                <span className="inline-flex items-center gap-1 rounded-full bg-gradient-to-r from-utility-blue-100 to-utility-blue-50 px-2.5 py-1 text-xs font-semibold text-utility-blue-700 ring-1 ring-utility-blue-300">
                                  ⚡ AMP
                                </span>
                              )}
                              {result.isWebStory && (
                                <span className="inline-flex items-center gap-1 rounded-full bg-gradient-to-r from-utility-purple-100 to-utility-purple-50 px-2.5 py-1 text-xs font-semibold text-utility-purple-700 ring-1 ring-utility-purple-300">
                                  📱 Story
                                </span>
                              )}
                              {result.isMalicious && (
                                <span className="inline-flex items-center gap-1 rounded-full bg-gradient-to-r from-utility-error-100 to-utility-error-50 px-2.5 py-1 text-xs font-semibold text-utility-error-700 ring-1 ring-utility-error-300 animate-pulse">
                                  ⚠️ Malicious
                                </span>
                              )}
                            </div>

                            {/* Rank Details */}
                            {(result.rankGroup || result.rankAbsolute) && (
                              <div className="flex items-center gap-2 mb-2">
                                {result.rankGroup && (
                                  <div className="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-utility-gray-100 border border-utility-gray-200">
                                    <span className="text-xs font-medium text-utility-gray-600">Group:</span>
                                    <span className="text-xs font-bold text-utility-gray-700">{result.rankGroup}</span>
                                  </div>
                                )}
                                {result.rankAbsolute && (
                                  <div className="inline-flex items-center gap-1 px-2 py-0.5 rounded-md bg-utility-gray-100 border border-utility-gray-200">
                                    <span className="text-xs font-medium text-utility-gray-600">Absolute:</span>
                                    <span className="text-xs font-bold text-utility-gray-700">{result.rankAbsolute}</span>
                                  </div>
                                )}
                              </div>
                            )}

                            {/* Website Name */}
                            {result.websiteName && result.websiteName !== result.domain && (
                              <p className="text-xs text-utility-gray-600 mb-1">
                                {result.websiteName}
                              </p>
                            )}

                            {/* Breadcrumb */}
                            {result.breadcrumb && (
                              <p className="text-xs text-utility-gray-500 mb-2 font-mono">
                                📁 {result.breadcrumb}
                              </p>
                            )}

                            {/* Title */}
                            {result.title && (
                              <h4 className="text-base font-semibold text-primary mb-2 leading-snug hover:text-utility-blue-600 transition-colors">
                                {result.title}
                              </h4>
                            )}

                            {/* Rating */}
                            {result.rating && (
                              <div className="inline-flex items-center gap-2 mb-2 px-3 py-1.5 rounded-lg bg-gradient-to-r from-utility-warning-50 to-utility-warning-50/30 border border-utility-warning-200">
                                <div className="flex items-center gap-0.5">
                                  {[...Array(5)].map((_, i) => (
                                    <span
                                      key={i}
                                      className={`text-base ${
                                        i < Math.floor(result.rating?.value || 0)
                                          ? "text-utility-warning-500 drop-shadow-sm"
                                          : "text-utility-gray-300"
                                      }`}
                                    >
                                      ★
                                    </span>
                                  ))}
                                </div>
                                <span className="text-xs font-semibold text-utility-warning-700">
                                  {result.rating.value?.toFixed(1)}
                                </span>
                                <span className="text-xs text-utility-warning-600">
                                  ({result.rating.votesCount?.toLocaleString()})
                                </span>
                              </div>
                            )}

                            {/* Price */}
                            {result.price && (
                              <div className="inline-flex items-center gap-2 mb-2 px-3 py-1.5 rounded-lg bg-gradient-to-r from-utility-success-50 to-utility-success-50/30 border border-utility-success-200">
                                <span className="text-base font-bold text-utility-success-700">
                                  {result.price.displayedPrice || `$${result.price.current}`}
                                </span>
                                {result.price.regular && result.price.regular > (result.price.current || 0) && (
                                  <div className="flex items-center gap-1">
                                    <span className="text-xs text-utility-error-600 line-through">
                                      ${result.price.regular.toFixed(2)}
                                    </span>
                                    <span className="text-xs font-semibold text-utility-success-600 px-1.5 py-0.5 rounded bg-utility-success-100">
                                      {Math.round((1 - (result.price.current || 0) / result.price.regular) * 100)}% OFF
                                    </span>
                                  </div>
                                )}
                              </div>
                            )}

                            {/* Description */}
                            {result.description && (
                              <p className="text-xs text-tertiary line-clamp-2 mb-1">
                                {result.description}
                              </p>
                            )}

                            {/* Highlighted Text */}
                            {result.highlighted && result.highlighted.length > 0 && (
                              <div className="mb-2 flex items-start gap-2">
                                <span className="text-xs font-semibold text-utility-blue-700 flex-shrink-0">🔦 Highlighted:</span>
                                <div className="flex flex-wrap gap-1">
                                  {result.highlighted.map((text, hIdx) => (
                                    <span key={hIdx} className="inline-flex items-center px-2 py-0.5 rounded-md bg-utility-blue-100 text-xs font-semibold text-utility-blue-700 border border-utility-blue-200">
                                      {text}
                                    </span>
                                  ))}
                                </div>
                              </div>
                            )}

                            {/* URL */}
                            <a
                              href={result.url}
                              target="_blank"
                              rel="noopener noreferrer"
                              className="text-xs text-utility-blue-600 hover:text-utility-blue-700 hover:underline break-all inline-block mb-2"
                            >
                              {result.url}
                            </a>

                            {/* Additional URL Info */}
                            {(result.mainDomain || result.relativeUrl) && (
                              <div className="flex items-center gap-3 mb-2">
                                {result.mainDomain && result.mainDomain !== result.domain && (
                                  <span className="text-xs text-tertiary">
                                    <span className="font-medium">Main Domain:</span> {result.mainDomain}
                                  </span>
                                )}
                                {result.relativeUrl && (
                                  <span className="text-xs text-tertiary">
                                    <span className="font-medium">Relative URL:</span> {result.relativeUrl}
                                  </span>
                                )}
                              </div>
                            )}

                            {/* ETV and Traffic Cost */}
                            {(result.etv || result.estimatedPaidTrafficCost) && (
                              <div className="flex items-center gap-2 mb-3 flex-wrap">
                                {result.etv && (
                                  <div className="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-utility-blue-50 border border-utility-blue-200">
                                    <span className="text-xs font-medium text-utility-blue-700">💰 ETV:</span>
                                    <span className="text-xs font-bold text-utility-blue-700">${result.etv.toLocaleString()}</span>
                                  </div>
                                )}
                                {result.estimatedPaidTrafficCost && (
                                  <div className="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-md bg-utility-purple-50 border border-utility-purple-200">
                                    <span className="text-xs font-medium text-utility-purple-700">📊 Traffic Cost:</span>
                                    <span className="text-xs font-bold text-utility-purple-700">${result.estimatedPaidTrafficCost.toLocaleString()}</span>
                                  </div>
                                )}
                              </div>
                            )}

                            {/* Sitelinks */}
                            {result.sitelinks && result.sitelinks.length > 0 && (
                              <div className="mt-3 p-3 rounded-lg bg-gradient-to-r from-utility-blue-50/50 to-transparent border-l-3 border-utility-blue-400">
                                <p className="text-xs font-semibold text-utility-blue-700 mb-2 flex items-center gap-1">
                                  🔗 Sitelinks ({result.sitelinks.length})
                                </p>
                                <div className="space-y-2">
                                  {result.sitelinks.slice(0, 4).map((link, linkIdx) => (
                                    <div key={linkIdx} className="pl-3">
                                      <a
                                        href={link.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        className="text-xs text-utility-blue-600 hover:text-utility-blue-700 hover:underline font-semibold flex items-center gap-1"
                                      >
                                        <span>→</span> {link.title}
                                      </a>
                                      {link.description && (
                                        <p className="text-xs text-tertiary line-clamp-1 ml-3 mt-0.5">
                                          {link.description}
                                        </p>
                                      )}
                                    </div>
                                  ))}
                                </div>
                              </div>
                            )}

                            {/* About This Result */}
                            {result.aboutThisResult && (
                              <div className="mt-3 p-3 rounded-lg bg-gradient-to-r from-utility-gray-50 to-utility-gray-50/30 border border-utility-gray-300">
                                <p className="text-xs font-semibold text-utility-gray-700 mb-2 flex items-center gap-1">
                                  ℹ️ About this result
                                </p>
                                <div className="space-y-1">
                                  {result.aboutThisResult.source && (
                                    <p className="text-xs text-tertiary">
                                      <span className="font-medium">Source:</span> {result.aboutThisResult.source}
                                    </p>
                                  )}
                                  {result.aboutThisResult.sourceInfo && (
                                    <p className="text-xs text-tertiary">
                                      {result.aboutThisResult.sourceInfo}
                                    </p>
                                  )}
                                  {result.aboutThisResult.sourceUrl && (
                                    <a
                                      href={result.aboutThisResult.sourceUrl}
                                      target="_blank"
                                      rel="noopener noreferrer"
                                      className="text-xs text-utility-blue-600 hover:text-utility-blue-700 hover:underline font-medium inline-flex items-center gap-1"
                                    >
                                      Learn more →
                                    </a>
                                  )}
                                </div>
                              </div>
                            )}

                            {/* Timestamp */}
                            {result.timestamp && (
                              <div className="inline-flex items-center gap-1.5 mt-2 px-2.5 py-1 rounded-md bg-utility-gray-100 border border-utility-gray-200">
                                <span className="text-xs text-utility-gray-600">🕐</span>
                                <span className="text-xs font-medium text-utility-gray-700">{result.timestamp}</span>
                              </div>
                            )}
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                  <div className="mt-4 pt-3 border-t border-utility-gray-200">
                    <div className="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-gradient-to-r from-utility-blue-50 to-utility-blue-50/30 border border-utility-blue-200">
                      <span className="text-xs font-medium text-utility-blue-700">📅 Last fetched:</span>
                      <span className="text-xs font-semibold text-utility-blue-900">{new Date(serpResults.fetchedAt).toLocaleString()}</span>
                    </div>
                  </div>
                </div>
              </div>
            )}

            {/* Last Updated */}
            {keyword.lastUpdated && (
              <div className="rounded-lg border border-secondary bg-secondary/30 p-4">
                <p className="text-xs font-medium text-tertiary mb-1">Last Updated</p>
                <p className="text-sm text-primary">
                  {new Date(keyword.lastUpdated).toLocaleString()}
                </p>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}
