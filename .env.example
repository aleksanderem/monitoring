# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Email Service (Resend)
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM="SEO Monitor <notifications@yourdomain.com>"

# App URL (for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (optional — button hidden when not set)
# Set NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true to show the Google sign-in button
# Set AUTH_GOOGLE_ID and AUTH_GOOGLE_SECRET on the Convex backend via:
#   npx convex env set AUTH_GOOGLE_ID <your-client-id>
#   npx convex env set AUTH_GOOGLE_SECRET <your-client-secret>
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=
